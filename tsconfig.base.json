{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "paths": {
      "@octopus/work-contracts": ["packages/work-contracts/dist/index.d.ts"],
      "@octopus/observability": ["packages/observability/dist/index.d.ts"],
      "@octopus/agent-runtime": ["packages/agent-runtime/dist/index.d.ts"],
      "@octopus/exec-substrate": ["packages/exec-substrate/dist/index.d.ts"],
      "@octopus/state-store": ["packages/state-store/dist/index.d.ts"],
      "@octopus/security": ["packages/security/dist/index.d.ts"],
      "@octopus/work-core": ["packages/work-core/dist/index.d.ts"],
      "@octopus/automation": ["packages/automation/dist/index.d.ts"],
      "@octopus/runtime-embedded": ["packages/runtime-embedded/dist/index.d.ts"],
      "@octopus/runtime-remote": ["packages/runtime-remote/dist/index.d.ts"],
      "@octopus/adapter-mcp": ["packages/adapter-mcp/dist/index.d.ts"],
      "@octopus/surfaces-chat": ["packages/surfaces-chat/dist/index.d.ts"],
      "@octopus/surfaces-cli": ["packages/surfaces-cli/dist/index.d.ts"],
      "@octopus/gateway": ["packages/gateway/dist/index.d.ts"],
      "@octopus/eval-runner": ["packages/eval-runner/dist/index.d.ts"],
      "@octopus/work-packs": ["packages/work-packs/dist/index.d.ts"]
    },
    "lib": ["ES2022"],
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true
  }
}
